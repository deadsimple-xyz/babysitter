#!/usr/bin/env ruby

$LOAD_PATH.unshift(File.expand_path("../lib", __dir__))

require "config"
require "supervisor"

def usage
  $stderr.puts <<~USAGE
    Usage: babysitter <workdir>

    Examples:
      babysitter .
      babysitter ../my-app
  USAGE
  exit 1
end

workdir = ARGV[0]
usage if workdir.nil? || workdir == "--help" || workdir == "-h"

unless File.directory?(workdir)
  $stderr.puts "Error: not a directory: #{workdir}"
  exit 1
end

# Get API key (prompts on first run)
Babysitter::Config.api_key!

# Ask what to do
$stderr.puts "What should I do?"
$stderr.print "> "
prompt = $stdin.gets&.strip

if prompt.nil? || prompt.empty?
  $stderr.puts "Nothing to do."
  exit 0
end

$stderr.puts ""

supervisor = Babysitter::Supervisor.new(
  working_dir: workdir,
  prompt: prompt
)

success = supervisor.run
exit(success ? 0 : 1)
