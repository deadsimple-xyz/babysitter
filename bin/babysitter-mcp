#!/usr/bin/env ruby

$LOAD_PATH.unshift(File.expand_path("../lib", __dir__))

require "gate"
require "compliance"
require "rules"
require "mcp_server"

rules = Babysitter::Rules.new
compliance = Babysitter::Compliance.new(rules: rules)
gate = Babysitter::Gate.new(compliance: compliance)
server = Babysitter::MCPServer.new(gate: gate)
server.run
